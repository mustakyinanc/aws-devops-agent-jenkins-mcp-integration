# Copy this file to .env and fill in your values for local development.
# Never commit .env to source control.

# Your Jenkins EC2 private IP and port
JENKINS_URL=http://10.0.x.x:8080

# Jenkins username (e.g. admin)
JENKINS_USER=admin

# Jenkins API token generated from Jenkins → your username → Configure → API Token
# Store this in AWS Secrets Manager or SSM Parameter Store for production
JENKINS_TOKEN=your-jenkins-api-token-here
